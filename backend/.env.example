# Core Gym Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT ───────────────────────────────────────────
JWT_SECRET=core-gym-dev-secret-change-in-production-2026
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=900000

